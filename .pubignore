# When .pubignore exists, dart pub publish uses ONLY this file — not .gitignore.
# Everything excluded from git must be re-listed here.

# AI planning docs
/docs/

# Build artifacts
/build/
/coverage/
.dart_tool/

# Rust build artifacts
/rust/target/
/Cargo.lock

# Android build artifacts
android/.gradle/
android/build/
android/local.properties

# iOS / macOS build artifacts
ios/build/
macos/build/
ios/Pods/
macos/Pods/
ios/.symlinks/
macos/.symlinks/

# xcframeworks are downloaded by CocoaPods (prepare_command) and SPM (remote binary target).
# Too large (~50 MB uncompressed) to include in the pub.dev tarball.
ios/Frameworks/
macos/Frameworks/

# Linux / Windows build artifacts
linux/build/
windows/build/

# Example app generated platform dirs (not part of the plugin)
example/ios/
example/android/
example/linux/
example/windows/
example/macos/
example/web/

# CI + local dev scripts — consumers only need pre-built binaries
scripts/

# Rust source — consumers use the pre-built binaries in platform dirs
/rust/

# Local dev test — not a consumer example
example/test/

# Community / dev-only docs not useful to pub.dev consumers
CLAUDE.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
image_asset.png
.github/
assets/

# Editor / OS
.DS_Store
.idea/
*.iml
*.ipr
*.iws
